          "attempts": [
            { "kind": "http_error", "status": 429, "retryAfter": "0" },
            {
              "kind": "text_stream",
              "protocol": "aws-event-stream",
              "crcBoundaryCoverage": true,
              "chunkSizes": [3, 1, 6, 2]
            }
          ],
          "expected": {
            "terminal": "completed",
            "text": "你好 👋 from mock.",
            "usage": { "inputTokens": 7, "outputTokens": 5, "totalTokens": 12 },
            "minRequests": 2,
            "requiredEventTypes": ["retry.scheduled", "message.delta", "run.completed"]
          }
        },
        {
          "name": "server_error_retry",
          "attempts": [
            {
              "kind": "http_error",
              "status": 503,
              "retryAfter": "Wed, 21 Oct 2037 07:28:00 GMT"
            },
            {
              "kind": "text_stream",
              "protocol": "aws-event-stream",
              "crcBoundaryCoverage": true,
              "chunkSizes": [5, 2, 1, 8]
            }
          ],
          "expected": {
            "terminal": "completed",
            "text": "你好 👋 from mock.",
            "usage": { "inputTokens": 7, "outputTokens": 5, "totalTokens": 12 },
            "minRequests": 2,
            "requiredEventTypes": ["retry.scheduled", "message.delta", "run.completed"]
          }
        },
        {
          "name": "disconnect",
          "attempts": [
            {
              "kind": "disconnect_stream",
              "protocol": "aws-event-stream",
              "crcBoundaryCoverage": true,
              "chunkSizes": [1, 3, 2]
            }
          ],
          "expected": {
            "terminal": "interrupted",
            "minRequests": 1,
            "requiredEventTypes": ["run.interrupted"]
          }
        },
        {
          "name": "idle_timeout",
          "attempts": [{ "kind": "idle_stream", "idleMs": 400 }],
          "expected": {
            "terminal": "failed",
            "minRequests": 1,
            "requiredEventTypes": ["run.failed"]
          }
        },
        {
          "name": "cancellation",
          "attempts": [{ "kind": "cancel_stream", "idleMs": 3000 }],
          "expected": {
            "terminal": "cancelled",
            "minRequests": 1,
            "requiredEventTypes": ["run.cancelled"]
          }
        }
      ]
    },
    {
