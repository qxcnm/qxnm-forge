{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.1/schemas/sponsored-provider-catalog.schema.json",
  "title": "Signed sponsored provider catalog",
  "$comment": "Author: 高宏顺 <18272669457@163.com>. The identifiers are intentionally brand-neutral.",
  "oneOf": [
    { "$ref": "#/$defs/trustKey" },
    { "$ref": "#/$defs/source" },
    { "$ref": "#/$defs/catalog" },
    { "$ref": "#/$defs/envelope" }
  ],
  "$defs": {
    "schemaVersion": { "const": "0.1" },
    "keyId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "algorithm": { "const": "ecdsa-p256-sha256-asn1" },
    "base64": {
      "type": "string",
      "minLength": 4,
      "maxLength": 349528,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    },
    "trustKey": {
      "type": "object",
      "required": ["schemaVersion", "keyId", "algorithm", "publicKey"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "keyId": { "$ref": "#/$defs/keyId" },
        "algorithm": { "$ref": "#/$defs/algorithm" },
        "publicKey": { "$ref": "#/$defs/base64" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["schemaVersion", "catalogUrl", "keyId", "algorithm", "publicKey"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "catalogUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
        "keyId": { "$ref": "#/$defs/keyId" },
        "algorithm": { "$ref": "#/$defs/algorithm" },
        "publicKey": { "$ref": "#/$defs/base64" }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": ["id", "displayName", "description", "apiFamily", "apiBaseUrl", "signupUrl", "commissionDisclosure", "priority"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "minLength": 1, "maxLength": 280 },
        "apiFamily": {
          "enum": ["openai-completions", "openai-responses", "anthropic-messages"]
        },
        "apiBaseUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
        "signupUrl": { "type": "string", "format": "uri", "maxLength": 2048 },
        "commissionDisclosure": { "type": "string", "minLength": 1, "maxLength": 240 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 1000 }
      },
      "additionalProperties": false
    },
    "catalog": {
      "type": "object",
      "required": ["schemaVersion", "catalogVersion", "issuedAt", "expiresAt", "entries"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "catalogVersion": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "issuedAt": { "$ref": "common.schema.json#/$defs/utcTime" },
        "expiresAt": { "$ref": "common.schema.json#/$defs/utcTime" },
        "entries": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/entry" }
        }
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "$ref": "#/$defs/algorithm" },
        "keyId": { "$ref": "#/$defs/keyId" },
        "value": { "$ref": "#/$defs/base64" }
      },
      "additionalProperties": false
    },
    "envelope": {
      "type": "object",
      "required": ["schemaVersion", "payload", "signature"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "payload": { "$ref": "#/$defs/base64" },
        "signature": { "$ref": "#/$defs/signature" }
      },
      "additionalProperties": false
    }
  }
}
