{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-conformance:provider-route-spine-config:0.1",
  "title": "Provider executable route spine conformance configuration",
  "$comment": "功能：约束 canonical Provider route 黑盒门禁的单 route、单模型、literal-loopback endpoint base；不得承载 credential、adapter、header 或 quirk。作者：高宏顺；邮箱：18272669457@163.com",
  "type": "object",
  "required": ["schemaVersion", "providerId", "apiFamily", "modelId", "endpointBase"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$",
      "maxLength": 128
    },
    "apiFamily": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "maxLength": 128
    },
    "modelId": {
      "type": "string",
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$",
      "maxLength": 256
    },
    "endpointBase": {
      "type": "string",
      "pattern": "^http://127\\.0\\.0\\.1:[1-9][0-9]{0,4}(?:/[A-Za-z0-9._~-]+)*$",
      "maxLength": 2048
    }
  },
  "additionalProperties": false
}
