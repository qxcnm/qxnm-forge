{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.3/schemas/custom-provider-connection.schema.json",
  "title": "Brand-neutral custom Provider connection DTO v0.3",
  "$comment": "Author: 高宏顺 <18272669457@163.com>. Connection DTOs never contain credentials.",
  "$ref": "#/$defs/connection",
  "$defs": {
    "httpsEndpoint": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://(?:\\[[0-9A-Fa-f:.]+\\]|[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)*\\.?)(?::(?:0|[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:/(?:[A-Za-z0-9._~!$&'()*+,;=:@/-]|%[0-9A-Fa-f]{2})*)?$",
      "maxLength": 2048
    },
    "connectionInput": {
      "type": "object",
      "required": [
        "displayName",
        "providerId",
        "apiFamily",
        "baseUrl",
        "modelsUrl",
        "modelIds",
        "supportsTools",
        "supportsImageInput",
        "supportsImageOutput",
        "logoAssetId",
        "enabled"
      ],
      "properties": {
        "displayName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$", "maxLength": 128 },
        "apiFamily": { "enum": ["openai-responses", "openai-completions"] },
        "baseUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelsUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "minItems": 0,
          "maxItems": 512,
          "uniqueItems": true
        },
        "supportsTools": { "type": "boolean" },
        "supportsImageInput": { "type": "boolean" },
        "supportsImageOutput": { "type": "boolean" },
        "logoAssetId": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9][a-z0-9.-]*$",
          "maxLength": 128
        },
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "connection": {
      "type": "object",
      "required": [
        "connectionId",
        "revision",
        "displayName",
        "providerId",
        "apiFamily",
        "baseUrl",
        "modelsUrl",
        "modelIds",
        "supportsTools",
        "supportsImageInput",
        "supportsImageOutput",
        "logoAssetId",
        "enabled",
        "credentialConfigured",
        "imageCredentialConfigured",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "connectionId": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/opaqueId" },
        "revision": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/positiveSafeInteger" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$", "maxLength": 128 },
        "apiFamily": { "enum": ["openai-responses", "openai-completions"] },
        "baseUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelsUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "minItems": 0,
          "maxItems": 512,
          "uniqueItems": true
        },
        "supportsTools": { "type": "boolean" },
        "supportsImageInput": { "type": "boolean" },
        "supportsImageOutput": { "type": "boolean" },
        "logoAssetId": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9][a-z0-9.-]*$",
          "maxLength": 128
        },
        "enabled": { "type": "boolean" },
        "credentialConfigured": { "type": "boolean" },
        "imageCredentialConfigured": { "type": "boolean" },
        "createdAt": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/utcTime" },
        "updatedAt": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/utcTime" }
      },
      "additionalProperties": false
    },
    "configuration": {
      "type": "object",
      "required": [
        "connectionId",
        "revision",
        "displayName",
        "providerId",
        "apiFamily",
        "baseUrl",
        "modelsUrl",
        "modelIds",
        "supportsTools",
        "supportsImageInput",
        "supportsImageOutput",
        "logoAssetId",
        "enabled",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "connectionId": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/opaqueId" },
        "revision": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/positiveSafeInteger" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$", "maxLength": 128 },
        "apiFamily": { "enum": ["openai-responses", "openai-completions"] },
        "baseUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelsUrl": { "$ref": "#/$defs/httpsEndpoint" },
        "modelIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "minItems": 0,
          "maxItems": 512,
          "uniqueItems": true
        },
        "supportsTools": { "type": "boolean" },
        "supportsImageInput": { "type": "boolean" },
        "supportsImageOutput": { "type": "boolean" },
        "logoAssetId": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9][a-z0-9.-]*$",
          "maxLength": 128
        },
        "enabled": { "type": "boolean" },
        "createdAt": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/utcTime" },
        "updatedAt": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/utcTime" }
      },
      "additionalProperties": false
    },
    "document": {
      "type": "object",
      "required": ["schemaVersion", "connections"],
      "properties": {
        "schemaVersion": { "const": "0.3" },
        "connections": {
          "type": "array",
          "items": { "$ref": "#/$defs/configuration" },
          "maxItems": 128
        }
      },
      "additionalProperties": false
    },
    "listParams": {
      "type": "object",
      "additionalProperties": false
    },
    "createParams": {
      "type": "object",
      "required": ["connection"],
      "properties": { "connection": { "$ref": "#/$defs/connectionInput" } },
      "additionalProperties": false
    },
    "updateParams": {
      "type": "object",
      "required": ["connectionId", "expectedRevision", "connection"],
      "properties": {
        "connectionId": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/opaqueId" },
        "expectedRevision": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/positiveSafeInteger" },
        "connection": { "$ref": "#/$defs/connectionInput" }
      },
      "additionalProperties": false
    },
    "deleteParams": {
      "type": "object",
      "required": ["connectionId", "expectedRevision"],
      "properties": {
        "connectionId": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/opaqueId" },
        "expectedRevision": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/positiveSafeInteger" }
      },
      "additionalProperties": false
    },
    "discoverModelsParams": {
      "type": "object",
      "required": ["connectionId", "expectedRevision"],
      "properties": {
        "connectionId": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/opaqueId" },
        "expectedRevision": { "$ref": "https://schemas.agentprotocol.local/spec/0.1/schemas/common.schema.json#/$defs/positiveSafeInteger" }
      },
      "additionalProperties": false
    },
    "discoverModelsResult": {
      "type": "object",
      "required": ["connection", "discoveredCount", "restartRequired"],
      "properties": {
        "connection": { "$ref": "#/$defs/connection" },
        "discoveredCount": { "type": "integer", "minimum": 1, "maximum": 512 },
        "restartRequired": { "const": true }
      },
      "additionalProperties": false
    },
    "credentialStatus": {
      "type": "object",
      "required": ["providerId", "credentialKind", "credentialConfigured", "restartRequired"],
      "properties": {
        "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$", "maxLength": 128 },
        "credentialKind": { "enum": ["responses", "image"] },
        "credentialConfigured": { "type": "boolean" },
        "restartRequired": { "const": true }
      },
      "additionalProperties": false
    }
  }
}
