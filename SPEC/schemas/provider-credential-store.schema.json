{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.1/schemas/provider-credential-store.schema.json",
  "title": "Local provider credential store",
  "$comment": "Author: 高宏顺 <18272669457@163.com>. Sensitive local state; never use as a fixture or protocol payload.",
  "type": "object",
  "required": ["schemaVersion", "credentials"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "credentials": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "required": ["providerId", "apiKey"],
        "properties": {
          "providerId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]{0,127}$"
          },
          "apiKey": { "type": "string", "minLength": 1, "maxLength": 16384 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
