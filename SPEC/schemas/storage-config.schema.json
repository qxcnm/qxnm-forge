{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.1/schemas/storage-config.schema.json",
  "title": "Application database configuration",
  "$comment": "Author: 高宏顺 <18272669457@163.com>. This DTO never contains a remote connection string value.",
  "type": "object",
  "required": ["schemaVersion", "provider", "maxConnections"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "provider": { "enum": ["sqlite", "postgresql", "mysql"] },
    "sqlitePath": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "connectionEnvironment": {
      "type": "string",
      "pattern": "^[A-Z_][A-Z0-9_]{0,127}$"
    },
    "maxConnections": { "type": "integer", "minimum": 1, "maximum": 128 }
  },
  "allOf": [
    {
      "if": {
        "properties": { "provider": { "const": "sqlite" } },
        "required": ["provider"]
      },
      "then": {
        "required": ["sqlitePath"],
        "not": { "required": ["connectionEnvironment"] }
      },
      "else": {
        "required": ["connectionEnvironment"],
        "not": { "required": ["sqlitePath"] }
      }
    }
  ],
  "additionalProperties": false
}

