{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.1/schemas/session/pi-v3-import-report.schema.json",
  "title": "qxnm-forge PI Session v3 one-way import report v0.1",
  "$comment": "Author: 高宏顺 <18272669457@163.com>",
  "$ref": "#/$defs/report",
  "$defs": {
    "reasonCode": {
      "enum": [
        "compaction_details_quarantined",
        "compaction_summary_usage_unavailable",
        "custom_message_context_excluded",
        "custom_semantics_excluded",
        "extension_details_quarantined",
        "label_semantics_extension_only",
        "sensitive_value_redacted",
        "source_path_not_persisted",
        "unknown_entry_type",
        "unsupported_content_block",
        "unsupported_message_role"
      ]
    },
    "entryReport": {
      "type": "object",
      "required": [
        "sourceLine",
        "sourceType",
        "disposition",
        "reasonCodes",
        "sourceLineSha256",
        "contextExcluded"
      ],
      "properties": {
        "sourceLine": {
          "type": "integer",
          "minimum": 2,
          "maximum": 1000000
        },
        "sourceEntryId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "sourceType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "disposition": {
          "enum": [
            "mapped_with_loss",
            "preserved_extension",
            "quarantined",
            "redacted",
            "skipped"
          ]
        },
        "reasonCodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/reasonCode" },
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true
        },
        "sourceLineSha256": {
          "$ref": "../common.schema.json#/$defs/sha256"
        },
        "targetRecordIds": {
          "type": "array",
          "items": { "$ref": "../common.schema.json#/$defs/opaqueId" },
          "maxItems": 8,
          "uniqueItems": true
        },
        "contextExcluded": {
          "type": "boolean"
        },
        "quarantinedValue": true,
        "extensions": {
          "$ref": "../common.schema.json#/$defs/extensions"
        }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": [
        "sourceEntries",
        "targetRecords",
        "mappedSourceEntries",
        "extensionSourceEntries",
        "reportedSourceEntries",
        "redactedValues",
        "skippedSourceEntries"
      ],
      "properties": {
        "sourceEntries": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "targetRecords": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "mappedSourceEntries": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "extensionSourceEntries": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "reportedSourceEntries": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "redactedValues": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        },
        "skippedSourceEntries": {
          "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
        }
      },
      "additionalProperties": false
    },
    "report": {
      "type": "object",
      "required": [
        "schemaVersion",
        "kind",
        "status",
        "source",
        "target",
        "counts",
        "warnings",
        "entries"
      ],
      "properties": {
        "schemaVersion": { "const": "0.1" },
        "kind": { "const": "pi-session-v3-import-report" },
        "status": {
          "enum": ["completed", "completed_with_warnings"]
        },
        "source": {
          "type": "object",
          "required": [
            "format",
            "version",
            "sessionId",
            "sha256",
            "byteLength",
            "referenceCommit",
            "sourcePathDisposition"
          ],
          "properties": {
            "format": { "const": "pi-session-v3" },
            "version": { "const": 3 },
            "sessionId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "sha256": {
              "$ref": "../common.schema.json#/$defs/sha256"
            },
            "byteLength": {
              "$ref": "../common.schema.json#/$defs/nonNegativeSafeInteger"
            },
            "referenceCommit": {
              "const": "3f9aa5d10b35223abf6146f960ff5cb5c68053ee"
            },
            "sourcePathDisposition": { "const": "not_persisted" }
          },
          "additionalProperties": false
        },
        "target": {
          "type": "object",
          "required": ["sessionId", "reportArtifactId"],
          "properties": {
            "sessionId": {
              "$ref": "../common.schema.json#/$defs/opaqueId"
            },
            "reportArtifactId": {
              "$ref": "../common.schema.json#/$defs/opaqueId"
            }
          },
          "additionalProperties": false
        },
        "counts": { "$ref": "#/$defs/counts" },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/reasonCode" },
          "maxItems": 32,
          "uniqueItems": true
        },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryReport" },
          "maxItems": 100000
        },
        "extensions": {
          "$ref": "../common.schema.json#/$defs/extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "completed" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "warnings": { "maxItems": 0 },
              "entries": { "maxItems": 0 }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "completed_with_warnings" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "entries": { "minItems": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
