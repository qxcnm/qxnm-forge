{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentprotocol.local/spec/0.1/schemas/hard-sandbox-cases.schema.json",
  "title": "qxnm-forge Linux Bubblewrap hard sandbox conformance cases",
  "$comment": "Author: 高宏顺 <18272669457@163.com>",
  "type": "object",
  "required": ["$schema", "schemaVersion", "profile", "platforms", "safety", "daemon", "cases"],
  "properties": {
    "$schema": {"const": "https://schemas.agentprotocol.local/spec/0.1/schemas/hard-sandbox-cases.schema.json"},
    "schemaVersion": {"const": "0.1"},
    "profile": {"const": "linux-bwrap-v1"},
    "platforms": {"const": ["linux"]},
    "safety": {
      "const": {
        "network":"loopback_listener_only",
        "networkProbe":"python_socket_connect",
        "workspace":"temporary_only",
        "outsideCanary":"random_per_run",
        "credentialCanary":"random_per_run",
        "descendantProbe":"fork_setsid",
        "failureMode":"fail_closed_no_host_fallback",
        "execution":{
          "overallTimeoutMs":20000,
          "caseTimeoutMs":3000,
          "treeProbeTimeoutMs":750,
          "maxOutputBytes":65536,
          "terminationGraceMs":250,
          "cleanupTimeoutMs":2000,
          "socketConnectTimeoutMs":500
        }
      }
    },
    "daemon": {
      "const": {
        "tool":"process.exec",
        "profileEnvironment":"AGENT_HARD_SANDBOX_PROFILE",
        "profile":"linux-bwrap-v1",
        "productionBackend":"/usr/bin/bwrap",
        "conformanceBackendEnvironment":"AGENT_HARD_SANDBOX_CONFORMANCE_BACKEND",
        "conformanceGate":{
          "cliArgument":"--conformance",
          "environment":{"name":"QXNM_FORGE_CONFORMANCE","value":"1"}
        },
        "sandboxRequest":{"profile":"linux-bwrap-v1","workspaceAccess":"read_only","network":"isolated"},
        "execution":{"caseTimeoutMs":12000,"readyTimeoutMs":2000,"descendantDelayMs":1200,"descendantSettleMs":1600},
        "positiveCases":[
          {"name":"daemon_read_only_isolation","kind":"isolation","workspaceAccess":"read_only","expected":{"terminationReason":"exit","containment":"os_isolation"}},
          {"name":"daemon_read_write_isolation","kind":"isolation","workspaceAccess":"read_write","expected":{"terminationReason":"exit","containment":"os_isolation"}},
          {"name":"daemon_timeout_descendant_cleanup","kind":"timeout","workspaceAccess":"read_write","expected":{"terminationReason":"timeout","containment":"os_isolation","escapedMarker":false}},
          {"name":"daemon_output_descendant_cleanup","kind":"output","workspaceAccess":"read_write","expected":{"terminationReason":"output_limit","containment":"os_isolation","escapedMarker":false}},
          {"name":"daemon_cancel_descendant_cleanup","kind":"cancel","workspaceAccess":"read_write","expected":{"terminationReason":"cancelled","containment":"os_isolation","escapedMarker":false}},
          {"name":"daemon_exit_descendant_cleanup","kind":"daemon_exit","workspaceAccess":"read_write","expected":{"escapedMarker":false}}
        ],
        "negativeCases":[
          {"name":"unconfigured_request_fails_closed","kind":"unconfigured_request","expected":{"failureKind":"sandbox_unavailable","childStarted":false,"hostFallback":false}},
          {"name":"missing_backend_startup_fails_closed","kind":"missing_backend","expected":{"failureKind":"sandbox_unavailable","childStarted":false,"hostFallback":false}},
          {"name":"writable_backend_startup_fails_closed","kind":"user_writable_backend","expected":{"failureKind":"sandbox_unavailable","childStarted":false,"hostFallback":false}},
          {"name":"setup_self_test_startup_fails_closed","kind":"setup_non_sandbox_backend","expected":{"failureKind":"sandbox_unavailable","childStarted":false,"hostFallback":false}}
        ],
        "productionGates":[
          {"name":"fixed_backend_advertises","kind":"fixed_backend","expected":{"advertised":true}},
          {"name":"conformance_backend_presence_fails_closed","kind":"override_presence","expected":{"failureKind":"sandbox_unavailable","advertised":false}}
        ]
      }
    },
    "cases": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {"$ref":"#/$defs/readOnlyCase"},
        {"$ref":"#/$defs/readWriteCase"},
        {"$ref":"#/$defs/missingBackendCase"},
        {"$ref":"#/$defs/writableBackendCase"}
      ]
    }
  },
  "$defs": {
    "isolationExpected": {
      "type": "object",
      "required": [
        "workspaceReadable","workspaceWritable","outsideInvisible","systemReadOnly",
        "networkIsolated","networkProbeExecuted","credentialAbsent","executionCompleted",
        "overallExecutionBounded","timeoutBounded","outputBounded",
        "cancelDescendantsTerminated","parentExitDescendantsTerminated","containment"
      ],
      "properties": {
        "workspaceReadable":{"const":true},
        "workspaceWritable":{"type":"boolean"},
        "outsideInvisible":{"const":true},
        "systemReadOnly":{"const":true},
        "networkIsolated":{"const":true},
        "networkProbeExecuted":{"const":true},
        "credentialAbsent":{"const":true},
        "executionCompleted":{"const":true},
        "overallExecutionBounded":{"const":true},
        "timeoutBounded":{"const":true},
        "outputBounded":{"const":true},
        "cancelDescendantsTerminated":{"const":true},
        "parentExitDescendantsTerminated":{"const":true},
        "containment":{"const":"os_isolation"}
      },
      "additionalProperties":false
    },
    "readOnlyCase": {
      "type":"object",
      "required":["name","workspaceAccess","network","expected"],
      "properties":{
        "name":{"const":"read_only_isolation"},
        "workspaceAccess":{"const":"read_only"},
        "network":{"const":"isolated"},
        "expected":{"$ref":"#/$defs/isolationExpected","properties":{"workspaceWritable":{"const":false}}}
      },
      "additionalProperties":false
    },
    "readWriteCase": {
      "type":"object",
      "required":["name","workspaceAccess","network","expected"],
      "properties":{
        "name":{"const":"read_write_isolation"},
        "workspaceAccess":{"const":"read_write"},
        "network":{"const":"isolated"},
        "expected":{"$ref":"#/$defs/isolationExpected","properties":{"workspaceWritable":{"const":true}}}
      },
      "additionalProperties":false
    },
    "missingBackendCase": {
      "type":"object",
      "required":["name","workspaceAccess","network","backendOverride","expected"],
      "properties":{
        "name":{"const":"missing_backend_fails_closed"},
        "workspaceAccess":{"const":"read_only"},
        "network":{"const":"isolated"},
        "backendOverride":{"const":"missing"},
        "expected":{
          "type":"object",
          "required":["failureKind","childStarted","hostFallback"],
          "properties":{
            "failureKind":{"const":"sandbox_unavailable"},
            "childStarted":{"const":false},
            "hostFallback":{"const":false}
          },
          "additionalProperties":false
        }
      },
      "additionalProperties":false
    },
    "writableBackendCase": {
      "type":"object",
      "required":["name","workspaceAccess","network","backendOverride","expected"],
      "properties":{
        "name":{"const":"writable_backend_fails_closed"},
        "workspaceAccess":{"const":"read_only"},
        "network":{"const":"isolated"},
        "backendOverride":{"const":"user_writable"},
        "expected":{
          "type":"object",
          "required":["failureKind","setupFailureKind","childStarted","hostFallback"],
          "properties":{
            "failureKind":{"const":"sandbox_unavailable"},
            "setupFailureKind":{"const":"sandbox_unavailable"},
            "childStarted":{"const":false},
            "hostFallback":{"const":false}
          },
          "additionalProperties":false
        }
      },
      "additionalProperties":false
    }
  },
  "additionalProperties": false
}
